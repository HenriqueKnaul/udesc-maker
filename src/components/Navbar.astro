---
const { pagina_ativa = "inicio" } = Astro.props;
---

<nav class="navbar">
  <a href="/" class="logo">
    <img src="/logo.png" alt="UDESC Maker" />
  </a>

  <button id="menu_toggle" class="menu_toggle" aria-label="Abrir menu">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <div id="nav_links" class="links">
    <a href="/" class={pagina_ativa === "inicio" ? "ativo" : ""}>Início</a>
    <a href="/projetos" class={pagina_ativa === "projetos" ? "ativo" : ""}>Projetos</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu_toggle');
  const links = document.getElementById('nav_links');

  if (btn && links) {
    btn.addEventListener('click', () => {
      links.classList.toggle('aberto');
    });
  }
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 48px;
    height: 64px;
    background: white;
    border-bottom: 1px solid #e5e7eb;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo img {
    height: 48px;
    width: auto;
  }

  .menu_toggle {
    display: none !important;
    background: none;
    border: none;
    cursor: pointer;
    color: #374151;
    padding: 8px;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .links a {
    text-decoration: none;
    color: #374151;
    padding: 8px 18px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }

  .links a:hover {
    background: #f0fdf4;
    color: #166534;
  }

  .links a.ativo {
    background: #166534;
    color: white;
  }

  .links a.ativo:hover {
    background: #14532d;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0 24px;
    }

    .menu_toggle {
      display: block !important;
    }

    .links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: white;
      flex-direction: column;
      align-items: flex-start;
      padding: 16px 24px;
      border-bottom: 1px solid #e5e7eb;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      gap: 12px;
    }

    .links.aberto {
      display: flex;
    }

    .links a {
      width: 100%;
      text-align: left;
      padding: 12px 16px;
    }
  }
</style>