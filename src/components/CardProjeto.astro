---
// dados que o card precisa receber de fora
interface Props {
  titulo: string;
  resumo: string;
  imagem: string;
  categorias: string[];
  idade_minima: string | number;
  duracao: string;
  dificuldade: string;
  slug: string;
}

const { titulo, resumo, imagem, categorias, idade_minima, duracao, dificuldade, slug } = Astro.props;

// define a cor do badge de dificuldade
const cor_dificuldade: Record<string, string> = {
  "iniciante": "badge_facil",
  "Fácil":     "badge_facil",
  "Médio":     "badge_medio",
  "intermediario": "badge_medio",
  "Difícil":   "badge_dificil",
  "avancado":  "badge_dificil",
};
---

<!-- card horizontal: imagem à esquerda, info à direita -->
<div class="card">
  <img src={imagem || "/images/placeholder.jpg"} alt={titulo} class="card_imagem" />

  <div class="card_info">
    <!-- tags de categoria -->
    <div class="card_categorias">
      {categorias.map(cat => (
        <span class="tag">{cat}</span>
      ))}
    </div>

    <h3>{titulo}</h3>
    <p class="card_resumo">{resumo}</p>

    <!-- idade, duração e dificuldade -->
    <div class="card_meta">
      <span class="meta_item">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
        </svg>
        {idade_minima}+ anos
      </span>

      <span class="meta_item">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        {duracao}
      </span>

      <span class={`badge_dif ${cor_dificuldade[dificuldade] ?? "badge_facil"}`}>
        {dificuldade}
      </span>
    </div>

    <a href={`/projects/${slug}`} class="botao_projeto">Ver Projeto →</a>
  </div>
</div>

<style>
  .card {
    display: flex;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
  }

  .card_imagem {
    width: 400px;
    min-height: 260px;
    object-fit: cover;
    flex-shrink: 0;
    background: #d1d5db;
    display: block;
  }

  .card_info {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card_categorias {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .tag {
    background: #166534;
    color: white;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 500;
  }

  .card_info h3 {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 10px;
    color: #1a1a1a;
  }

  .card_resumo {
    color: #374151;
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .card_meta {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
  }

  .meta_item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #374151;
  }

  .badge_dif {
    padding: 3px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
  }

  .badge_facil   { background: #dcfce7; color: #166534; }
  .badge_medio   { background: #fef9c3; color: #854d0e; }
  .badge_dificil { background: #fee2e2; color: #991b1b; }

  .botao_projeto {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #166534;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    align-self: flex-start;
  }

  .botao_projeto:hover { background: #14532d; }
</style>