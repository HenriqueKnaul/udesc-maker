---
export interface Props {
  slug: string;
  titulo: string;
  resumo: string;
  imagem: string;
  dificuldade: 'iniciante' | 'intermediario' | 'avancado';
  categorias: string[];
  idade_minima: number;
  duracao: string;
  autor: string;
  variante?: 'grade' | 'lista';
}

const {
  slug,
  titulo,
  resumo,
  imagem,
  dificuldade,
  categorias,
  idade_minima,
  duracao,
  variante = 'grade',
} = Astro.props;

const dificuldade_classe: Record<string, string> = {
  iniciante:     'nivel_iniciante',
  intermediario: 'nivel_intermediario',
  avancado:      'nivel_avancado',
};

const dificuldade_label: Record<string, string> = {
  iniciante:     'Iniciante',
  intermediario: 'Intermediário',
  avancado:      'Avançado',
};
---

{variante === 'grade' ? (
  <a href={`/projects/${slug}`} class="card card_grade">
    <div class="grade_imagem_wrap">
      <img src={imagem} alt={titulo} class="card_imagem" loading="lazy" />
      <span class={`nivel_badge ${dificuldade_classe[dificuldade] ?? ''}`}>
        {dificuldade_label[dificuldade] ?? dificuldade}
      </span>
    </div>
    <div class="card_corpo">
      <div class="card_categorias">
        {(categorias ?? []).map(cat => <span class="categoria_tag">{cat}</span>)}
      </div>
      <h3 class="card_titulo">{titulo}</h3>
      <p class="card_resumo">{resumo}</p>
      <div class="card_meta">
        <span class="meta_item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {idade_minima}+ anos
        </span>
        <span class="meta_item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {duracao}
        </span>
      </div>
    </div>
  </a>
) : (
  <div class="card card_lista">
    <div class="lista_imagem_wrap">
      <img src={imagem} alt={titulo} class="card_imagem" loading="lazy" />
    </div>
    <div class="card_corpo">
      <div class="card_categorias">
        {(categorias ?? []).map(cat => <span class="categoria_tag">{cat}</span>)}
      </div>
      <h3 class="card_titulo">{titulo}</h3>
      <p class="card_resumo lista_resumo">{resumo}</p>
      <div class="card_meta">
        <span class="meta_item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {idade_minima}+ anos
        </span>
        <span class="meta_item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {duracao}
        </span>
        <span class={`nivel_badge_inline ${dificuldade_classe[dificuldade] ?? ''}`}>
          {dificuldade_label[dificuldade] ?? dificuldade}
        </span>
      </div>
      <a href={`/projects/${slug}`} class="botao_ver">Ver Projeto →</a>
    </div>
  </div>
)}

<style>
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .card_imagem {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .card:hover .card_imagem { transform: scale(1.04); }

  .card_grade {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .grade_imagem_wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #f3f4f6;
    flex-shrink: 0;
  }
  .nivel_badge {
    position: absolute;
    top: 12px;
    right: 12px;
    padding: 4px 14px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .card_lista {
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }
  .lista_imagem_wrap {
    width: 240px;
    flex-shrink: 0;
    overflow: hidden;
    background: #f3f4f6;
  }
  .lista_resumo {
    display: block !important;
    -webkit-line-clamp: unset !important;
    overflow: visible !important;
  }
  .nivel_badge_inline {
    padding: 3px 12px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .botao_ver {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 16px;
    background: #166534;
    color: #fff;
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 9px 20px;
    border-radius: 8px;
    width: fit-content;
    transition: background 0.15s;
  }
  .botao_ver:hover { background: #14532d; }

  .nivel_iniciante     { background: #dcfce7; color: #166534; }
  .nivel_intermediario { background: #fef3c7; color: #92400e; }
  .nivel_avancado      { background: #fee2e2; color: #991b1b; }

  .card_corpo {
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .card_categorias { display: flex; flex-wrap: wrap; gap: 6px; }
  .categoria_tag {
    background: #166534;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 999px;
  }
  .card_titulo {
    font-size: 1.05rem;
    font-weight: 700;
    color: #111827;
    line-height: 1.35;
    margin: 0;
  }
  .card_resumo {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card_meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: #9ca3af;
    margin-top: auto;
  }
  .meta_item {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  @media (max-width: 640px) {
    .card_lista {
      flex-direction: column;
    }
    .lista_imagem_wrap {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }
</style>