---
import BaseLayout from "../layouts/BaseLayout.astro";
import CardProjeto from "../components/CardProjeto.astro";
import { getCollection } from "astro:content";

const todos_projetos = await getCollection("projects", ({ data }) => {
  return data.visivel === true;
});

const QUANTIDADE_INICIAL = 3;
---

<BaseLayout titulo_pagina="UDESC MAKER" pagina_ativa="inicio">

  <section class="hero">
    <div class="hero_escurecimento"></div>
    <div class="hero_conteudo">
      <h1>Transforme Ideias e<br />Realidade</h1>
      <p>
        Plataforma dedicada a fomentar a cultura maker na UDESC e levá-la
        à comunidade local. Explore projetos incríveis que combinam
        tecnologia, criatividade e impacto social.
      </p>
      <a href="/projetos" class="botao_explorar">Explorar Projetos →</a>
    </div>
  </section>

  <section class="destaque">
    <div class="destaque_cabecalho">
      <div>
        <h2>Projetos em Destaque</h2>
        <p class="destaque_subtitulo">Conheça alguns dos projetos mais populares da nossa comunidade</p>
      </div>
      <a href="/projetos" class="botao_ver_todos">Ver Todos →</a>
    </div>

    <div class="lista_projetos" id="lista_projetos">
      {todos_projetos.map((projeto, indice) => (
        <div
          class="item_projeto"
          data-indice={indice}
          style={indice >= QUANTIDADE_INICIAL ? "display:none" : ""}
        >
          <CardProjeto
            titulo={projeto.data.titulo}
            resumo={projeto.data.resumo}
            imagem={projeto.data.thumbnail ?? "/images/placeholder.jpg"}
            categorias={projeto.data.categoria}
            idade_minima={projeto.data.idade_minima}
            duracao={projeto.data.duracao}
            dificuldade={projeto.data.dificuldade}
            variante="lista"
            slug={projeto.id}
            autor={projeto.data.autor}
          />
        </div>
      ))}
    </div>

    <div class="botao_carregar_wrap">
      <button class="botao_carregar" id="botao_carregar">Carregar Mais</button>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ QUANTIDADE_INICIAL, total_projetos: todos_projetos.length }}>
  const botao = document.getElementById("botao_carregar");

  if (botao) {
    let visiveis = QUANTIDADE_INICIAL;

    botao.addEventListener("click", () => {
      if (visiveis >= total_projetos) {
        window.location.href = "/projetos";
        return;
      }

      const itens = document.querySelectorAll("#lista_projetos .item_projeto");
      const proximo = Math.min(visiveis + 3, total_projetos);

      for (let i = visiveis; i < proximo; i++) {
        itens[i].style.display = "";
      }

      visiveis = proximo;

      if (visiveis >= total_projetos) {
        botao.textContent = "Ver Todos os Projetos →";
      }
    });
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: 460px;
    display: flex;
    align-items: center;
    background: url('/images/hero-bg.jpg') center/cover no-repeat;
    background-color: #222;
  }
  .hero_escurecimento {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }
  .hero_conteudo {
    position: relative;
    z-index: 1;
    padding: 64px 48px;
    color: white;
    max-width: 620px;
  }
  .hero_conteudo h1 {
    font-size: 50px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .hero_conteudo p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 32px;
    max-width: 520px;
  }
  .botao_explorar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #166534;
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
  }
  .botao_explorar:hover { background: #14532d; }
  .destaque {
    padding: 64px 48px;
    background: white;
  }
  .destaque_cabecalho {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 36px;
  }
  .destaque h2 {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .destaque_subtitulo {
    color: #166534;
    font-size: 14px;
  }
  .botao_ver_todos {
    text-decoration: none;
    color: #1a1a1a;
    font-weight: 500;
    border: 1px solid #d1d5db;
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 14px;
    white-space: nowrap;
  }
  .botao_ver_todos:hover { border-color: #166534; color: #166534; }
  .lista_projetos {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .botao_carregar_wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }
  .botao_carregar {
    background: #166534;
    color: white;
    padding: 12px 32px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    border: none;
    cursor: pointer;
  }
  .botao_carregar:hover { background: #14532d; }

  @media (max-width: 768px) {
    .hero_conteudo { padding: 40px 24px; }
    .hero_conteudo h1 { font-size: 36px; }
    .destaque { padding: 40px 24px; }
    .destaque_cabecalho { 
      flex-direction: column; 
      align-items: flex-start; 
      gap: 16px; 
    }
  }
</style>