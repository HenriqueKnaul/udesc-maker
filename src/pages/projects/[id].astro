---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  return allProjects.map(project => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const cor_dificuldade: Record<string, string> = {
  iniciante: 'badge_iniciante',
  intermediario: 'badge_intermediario',
  avancado: 'badge_avancado',
};

const label_dificuldade: Record<string, string> = {
  iniciante: 'Iniciante',
  intermediario: 'Intermediário',
  avancado: 'Avançado',
};
---

<BaseLayout titulo_pagina={`${d.titulo} — UDESC MAKER`} pagina_ativa="projetos">

  <div class="topbar">
    <a href="/projetos" class="botao_voltar">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Voltar
    </a>
    <button id="btn_compartilhar" class="botao_compartilhar">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
      <span>Compartilhar</span>
    </button>
  </div>

  <div class="pagina_wrap">

    <div class="projeto_hero">
      <div class="projeto_imagem_container">
        <img
          src={d.thumbnail ?? '/images/placeholder.jpg'}
          alt={d.titulo}
          class="projeto_imagem"
        />
        {d.autor && (
          <div class="projeto_autor">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            <span>Postado por: <strong>{d.autor}</strong></span>
          </div>
        )}
      </div>

      <div class="projeto_meta">
        <span class={`badge_dif ${cor_dificuldade[d.dificuldade] ?? ''}`}>
          {label_dificuldade[d.dificuldade] ?? d.dificuldade}
        </span>

        <h1>{d.titulo}</h1>
        <p class="projeto_resumo">{d.resumo}</p>

        <div class="projeto_categorias">
          {d.categoria.map((cat: string) => (
            <span class="categoria_tag">{cat}</span>
          ))}
        </div>

        <hr class="divisor" />

        <div class="projeto_infos">
          <div class="info_item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
            <div>
              <span class="info_label">Idade Mínima</span>
              <span class="info_valor">{d.idade_minima}+ anos</span>
            </div>
          </div>
          <div class="info_item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <div>
              <span class="info_label">Duração</span>
              <span class="info_valor">{d.duracao}</span>
            </div>
          </div>
        </div>

        <hr class="divisor" />

        {d.tags && d.tags.length > 0 && (
          <div class="projeto_tags_wrap">
            <span class="tags_label">TAGS</span>
            <div class="projeto_tags">
              {d.tags.map((tag: string) => (
                <span class="hashtag">#{tag}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="secoes">
      <div class="prose_wrapper">
        <Content />
      </div>

      <div class="recursos_bloco">
        <div class="recursos_cabecalho">
          <div class="recursos_icone">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </div>
          <span>Recursos Adicionais</span>
        </div>
        
        {d.recursos && d.recursos.length > 0 ? (
          <div class="recursos_grid">
            {d.recursos.map((rec: any) => (
              <a href={rec.url} target="_blank" class="recurso_card">
                <div class="recurso_icone_wrap">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                  </svg>
                </div>
                <div>
                  <span class="recurso_nome">{rec.nome}</span>
                  <span class="recurso_tipo">{rec.tipo}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="recursos_vazio">
            <p>Nenhum arquivo vinculado ainda.</p>
          </div>
        )}
      </div>
    </div>

  </div>

</BaseLayout>

<script>
  const btn = document.getElementById('btn_compartilhar');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const originalContent = btn.innerHTML;
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#166534" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> <span style="color: #166534;">Copiado!</span>`;
        btn.style.borderColor = "#166534";
        setTimeout(() => {
          btn.innerHTML = originalContent;
          btn.style.borderColor = "";
        }, 2000);
      } catch (err) {
        console.error('Falha ao copiar:', err);
      }
    });
  }
</script>

