    border-radius: 8px; 
    padding: 12px 16px; 
    background: #f9fafb; 
    text-decoration: none; 
    transition: all 0.2s; 
  }

  .recurso_card:hover { 
    border-color: #166534; 
    background: white; 
  }

  .recurso_icone_wrap { 
    width: 36px; 
    height: 36px; 
